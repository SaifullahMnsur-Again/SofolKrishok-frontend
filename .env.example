# ============================================
# SOFOLKRISHOK FRONTEND ENVIRONMENT CONFIG
# ============================================
# Copy this file to .env and set appropriate values for your environment.
# NEVER commit .env to version control!

# API_BASE_URL: Backend API endpoint
# 
# LOCAL DEVELOPMENT:
#   VITE_API_BASE_URL=/api
#   (Vite proxy defined in vite.config.js forwards /api to http://localhost:8000)
#
# PRODUCTION (DigitalOcean):
#   VITE_API_BASE_URL=/api
#   (Nginx reverse proxy handles /api/* routing to Django backend)
#   OR use full URL if backend is on different domain:
#   VITE_API_BASE_URL=https://api.your-domain.com

VITE_API_BASE_URL=/api

# ============================================
# DEVELOPMENT NOTES
# ============================================
#
# LOCAL:
# 1. Copy to .env
# 2. Run: npm install && npm run dev
# 3. Vite dev server: http://localhost:5173
# 4. Backend should run on: http://localhost:8000
#
# PRODUCTION:
# 1. Copy to .env
# 2. Run: npm run build (creates dist/)
# 3. Frontend served from: https://subdomain.domain.tld
# 4. Backend at: https://subdomain.domain.tld/api
#
